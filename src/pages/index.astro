---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const [featured, ...rest] = posts;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				max-width: 960px;
				width: calc(100% - 2em);
				margin: auto;
				padding: 2em 1em 4em;
			}

			.section-heading {
				font-size: 0.85rem;
				font-weight: 700;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				color: rgb(var(--gray));
				margin: 0 0 1.5rem;
			}

			/* Featured post */
			.featured {
				margin-bottom: 3rem;
			}

			.featured-link {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 2rem;
				text-decoration: none;
				color: inherit;
				border-radius: 16px;
				overflow: hidden;
				transition: box-shadow 0.2s ease;
			}

			.featured-link:hover {
				box-shadow: var(--box-shadow);
			}

			.featured-link:hover .featured-title {
				color: var(--accent);
			}

			.featured-image {
				aspect-ratio: 16 / 9;
				overflow: hidden;
				border-radius: 12px;
			}

			.featured-image img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				margin: 0;
				border-radius: 12px;
				transition: transform 0.3s ease;
			}

			.featured-link:hover .featured-image img {
				transform: scale(1.03);
			}

			.featured-body {
				display: flex;
				flex-direction: column;
				justify-content: center;
				gap: 0.75rem;
			}

			.featured-date {
				font-size: 0.9rem;
				color: rgb(var(--gray));
				margin: 0;
			}

			.featured-title {
				font-size: 2rem;
				line-height: 1.2;
				margin: 0;
				color: rgb(var(--black));
				transition: color 0.2s ease;
			}

			.featured-description {
				color: rgb(var(--gray-dark));
				font-size: 1rem;
				line-height: 1.6;
				margin: 0;
			}

			.read-more {
				display: inline-flex;
				align-items: center;
				gap: 0.3em;
				font-size: 0.95rem;
				font-weight: 700;
				color: var(--accent);
				margin-top: 0.25rem;
			}

			/* Post grid */
			.post-grid {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 2rem;
			}

			.post-card {
				text-decoration: none;
				color: inherit;
				display: flex;
				flex-direction: column;
				gap: 0.75rem;
				transition: box-shadow 0.2s ease;
				border-radius: 12px;
				padding: 0.25rem;
			}

			.post-card:hover {
				box-shadow: var(--box-shadow);
			}

			.post-card:hover .post-title {
				color: var(--accent);
			}

			.post-card-image {
				aspect-ratio: 16 / 9;
				overflow: hidden;
				border-radius: 10px;
			}

			.post-card-image img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				margin: 0;
				transition: transform 0.3s ease;
			}

			.post-card:hover .post-card-image img {
				transform: scale(1.03);
			}

			.post-meta {
				display: flex;
				flex-direction: column;
				gap: 0.4rem;
				padding: 0 0.25rem;
			}

			.post-date {
				font-size: 0.85rem;
				color: rgb(var(--gray));
				margin: 0;
			}

			.post-title {
				font-size: 1.25rem;
				line-height: 1.3;
				margin: 0;
				color: rgb(var(--black));
				transition: color 0.2s ease;
			}

			.post-description {
				font-size: 0.95rem;
				color: rgb(var(--gray-dark));
				line-height: 1.5;
				margin: 0;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			hr.divider {
				border: none;
				border-top: 1px solid rgb(var(--gray-light));
				margin: 2.5rem 0;
			}

			@media (max-width: 720px) {
				.featured-link {
					grid-template-columns: 1fr;
				}

				.post-grid {
					grid-template-columns: 1fr;
				}

				.featured-title {
					font-size: 1.5rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			{
				featured && (
					<section class="featured">
						<p class="section-heading">Latest Post</p>
						<a href={`/blog/${featured.id}/`} class="featured-link">
							{featured.data.heroImage && (
								<div class="featured-image">
									<Image
										width={720}
										height={405}
										src={featured.data.heroImage}
										alt=""
									/>
								</div>
							)}
							<div class="featured-body">
								<p class="featured-date">
									<FormattedDate date={featured.data.pubDate} />
								</p>
								<h2 class="featured-title">{featured.data.title}</h2>
								<p class="featured-description">{featured.data.description}</p>
								<span class="read-more">Read article →</span>
							</div>
						</a>
					</section>
				)
			}

			{
				rest.length > 0 && (
					<>
						<hr class="divider" />
						<p class="section-heading">More Posts</p>
						<div class="post-grid">
							{rest.map((post) => (
								<a href={`/blog/${post.id}/`} class="post-card">
									{post.data.heroImage && (
										<div class="post-card-image">
											<Image width={480} height={270} src={post.data.heroImage} alt="" />
										</div>
									)}
									<div class="post-meta">
										<p class="post-date">
											<FormattedDate date={post.data.pubDate} />
										</p>
										<h3 class="post-title">{post.data.title}</h3>
										<p class="post-description">{post.data.description}</p>
									</div>
								</a>
							))}
						</div>
					</>
				)
			}
		</main>
		<Footer />
	</body>
</html>
